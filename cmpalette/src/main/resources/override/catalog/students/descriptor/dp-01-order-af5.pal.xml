<?xml version='1.0' encoding='UTF-8'?>
<catalog xmlns="http://www.intertrust.ru/schema/palette/cat-ui">
  <custom-descriptor ident="Order" view="Orders_(vw_cmj_all)" id="dp-01-order-af5" name="Приказ" style="default">
    <builder name="ru.intertrust.cm_sochi.srv.uicollections.UiBuilder"/>
    <table>
      <columns>
        <column-ref ref="self"/>
        <column-ref ref="docNum" filter="true" sort-asc="true" sort-desc="true"/>
        <column-ref ref="group_st" filter="true" sort-asc="true" sort-desc="true"/>
        <column-ref ref="speciality" filter="true"/>
        <column-ref ref="course" filter="true"/>
        <column-ref ref="docDate" filter="true" sort-asc="true" sort-desc="true"/>
      </columns>
    </table>
  </custom-descriptor>
  <column name="docNum" extends="string" subject="${nameFull:Номер документа}"/>
  <column name="group_st" extends="string" subject="${birthDate:Группа}"/>
  <column name="speciality" extends="string" subject="${startDate:Специальность}"/>
  <column name="course" extends="string" subject="${group:Курс}"/>
  <column name="docDate" extends="date" subject="${course:Дата документа}"/>
</catalog>