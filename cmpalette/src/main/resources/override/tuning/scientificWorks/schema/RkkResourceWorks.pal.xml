<?xml version='1.0' encoding='UTF-8'?>
<schemas xmlns="http://www.intertrust.ru/schema/palette/tn-schema">
  <schema extends="RkkResource" name="RkkResourceWorks">
    <string name="showIdent" temporal="true">
      <calc-values>
        <script event="open" lang="SPEL"><![CDATA['Научные работы']]></script>
      </calc-values>
    </string>
    <string name="Tema" required="true">
      <storage-field name="Tema"/>
    </string>
    <string name="Field">
      <storage-field name="Field"/>
    </string>
    <actor name="Author" required="true">
      <storage-field name="Author"/>
    </actor>
    <actor name="CoAuthor">
      <storage-field name="CoAuthor"/>
    </actor>
    <date name="RegistrationDate" default-value="current">
      <storage-field name="RegistrationDate"/>
    </date>
    <file name="Materials">
      <storage-field name="{Materials}"/>
    </file>
  </schema>
</schemas>